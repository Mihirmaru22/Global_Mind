# Google AI Studio — Gemini Flash (free tier)
GEMINI_API_KEY=
# NVIDIA NIM — build.nvidia.com (free, no card)
NVIDIA_NIM_API_KEY=

# Groq — console.groq.com (free tier)
GROQ_API_KEY=

# OCR.space — ocr.space/ocrapi (free, 25K req/month)
OCR_SPACE_API_KEY=

# Jina AI — embeddings + reranker (forever-free tier)
JINA_API_KEY=

# Qdrant Cloud — cloud.qdrant.io (free cluster)
QDRANT_URL=
QDRANT_API_KEY=

# OpenRouter — openrouter.ai (optional bonus lane)
OPENROUTER_API_KEY=

# --- Auto-ingestion drop-folder (optional) ---
# Files placed in data/inbox/ are ingested by the /ingest/folder endpoint or,
# if enabled below, automatically. Content-addressed dedup keeps scans
# idempotent, so files can stay in the folder without creating duplicates.
# Scan the folder once when the server starts:
AUTO_INGEST_ON_STARTUP=false
# Re-scan the folder every N seconds in the background (0 = disabled):
AUTO_INGEST_INTERVAL_SECONDS=0

# --- Text-to-SQL live data (optional) ---
# "sqlite" (default, uses data/live_data.db) or "mysql"
DB_ENGINE=sqlite
# Only needed if DB_ENGINE=mysql. DB_READONLY_USER should have ONLY
# SELECT granted — that's the real write-prevention mechanism, not just
# the query validation in code.
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_READONLY_USER=
DB_READONLY_PASSWORD=
