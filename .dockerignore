# Keep the build context (and image) lean.
.git
.venv
venv
**/__pycache__
**/*.pyc
.pytest_cache
*.bundle

# Docs, dev scripts, and the test suite aren't needed in the runtime image.
docs/
scripts/
tests/

# Node/build tooling — the *built* output in frontend/ is what we ship, not the
# React source or its 100s of MB of node_modules.
LocalMind_UI/node_modules
node_modules

# Runtime state — recreated on startup; never bake it into the image.
data/

# Local secrets — provided as environment variables on the host instead.
.env
